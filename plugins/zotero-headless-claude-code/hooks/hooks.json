{
  "description": "Zotero-headless session hooks for Claude Code",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
