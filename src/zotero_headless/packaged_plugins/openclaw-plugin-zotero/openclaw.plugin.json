{
  "id": "zotero",
  "name": "Zotero",
  "description": "Zotero library access via zotero-headless daemon",
  "configSchema": {
    "daemon": {
      "type": "object",
      "properties": {
        "host": { "type": "string", "default": "127.0.0.1" },
        "port": { "type": "number", "default": 23119 },
        "syncOnStartup": { "type": "boolean", "default": true }
      }
    },
    "libraries": {
      "type": "object",
      "description": "Per-library permission overrides keyed by library ID (e.g. user:123456)",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "read":        { "type": "boolean", "default": true },
          "add":         { "type": "boolean", "default": true },
          "write":       { "type": "boolean", "default": false },
          "sync":        { "type": "boolean", "default": false },
          "attachments": { "type": "boolean", "default": false },
          "export":      { "type": "boolean", "default": true },
          "backup":      { "type": "boolean", "default": false }
        }
      }
    },
    "defaultPermissions": {
      "type": "object",
      "properties": {
        "read":        { "type": "boolean", "default": true },
        "add":         { "type": "boolean", "default": true },
        "write":       { "type": "boolean", "default": false },
        "sync":        { "type": "boolean", "default": false },
        "attachments": { "type": "boolean", "default": false },
        "export":      { "type": "boolean", "default": true },
        "backup":      { "type": "boolean", "default": false }
      }
    }
  },
  "kind": "capability"
}
